# ==========================================
# 1. SERVER & ENVIRONMENT
# ==========================================
PORT=8000
NODE_ENV=development
FRONTEND_URL=https://your-production-frontend-url.vercel.app

# ==========================================
# 2. DATABASE
# ==========================================
# Master MongoDB connection string
MONGO_URI=mongodb://localhost:27017/StudentNeeds

# Redis connection string (for Queues and WebSockets)
REDIS_URL=redis://localhost:6379

# ==========================================
# 3. SECURITY & AUTHENTICATION
# ==========================================
# JWT Token Signing Secret
JWT_SECRET=
# Express Session Secret
SESSION_SECRET=

# ==========================================
# 4. MAILING / SMTP (Expenses & Tutorials)
# ==========================================
SMTP_USER=
SMTP_PASS=

# ==========================================
# 5. CLOUDINARY MEDIA STORAGE (Tutorials & Referrals)
# ==========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# 6. EXTERNAL AI INTEGRATIONS (Referrals)
# ==========================================
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
